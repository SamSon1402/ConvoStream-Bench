# Provider keys are OPTIONAL.
# The synthetic target works with no keys configured (useful for engine smoke tests).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

LOG_LEVEL=INFO

# Engine limits (per-run config is bounded by these)
MAX_CONCURRENCY=1024
MAX_DURATION_S=3600

# WebSocket cadence (ms between snapshots)
SNAPSHOT_INTERVAL_MS=500

# Bottleneck detector
P99_SPIKE_MULTIPLIER=1.6
P99_SMOOTHING_ALPHA=0.2
SPIKE_MIN_SAMPLES=50

# HTTP client
REQUEST_TIMEOUT_S=30
CONNECT_TIMEOUT_S=5
